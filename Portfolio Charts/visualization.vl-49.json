{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "The UK consistently ranks last in the G7 for capital investment",
    "subtitle": [
      "G7 Gross Fixed Capital Formation as a % of GDP. Chained volume measures, seasonally adjusted.",
      "Source: ONS & OECD",
      ""
    ],
    "anchor": "start"
  },
  "width": 600,
  "height": 400,
  "data": {
    "url": "https://raw.githubusercontent.com/georgerushworth/georgerushworth.github.io/refs/heads/main/Portfolio%20Charts/GFCF%20Data.csv",
    "format": {"type": "csv"}
  },
  "transform": [
    {
      "fold": [
        "Canada",
        "France",
        "Germany",
        "Italy",
        "Japan",
        "United States",
        "United Kingdom"
      ],
      "as": ["Country", "GFCF"]
    },
    {"calculate": "toNumber(datum.GFCF)", "as": "GFCF"}
  ],
  "layer": [
    {
      "mark": {"type": "line", "point": false},
      "encoding": {
        "x": {
          "field": "Quarter",
          "type": "ordinal",
          "title": null,
          "axis": {"grid": false, "labelAngle": -45}
        },
        "y": {
          "field": "GFCF",
          "type": "quantitative",
          "title": "% of GDP",
          "scale": {"zero": false},
          "axis": {
            "grid": true,
            "gridDash": [1, 5],
            "gridOpacity": 0.5,
            "ticks": false,
            "labelPadding": 5,
            "titleAngle": 0,
            "titleAlign": "left",
            "titleBaseline": "bottom",
            "titleX": 0,
            "titleY": -5
          }
        },
        "color": {
          "field": "Country",
          "type": "nominal",
          "scale": {
            "domain": [
              "Canada",
              "France",
              "Germany",
              "Italy",
              "Japan",
              "United States",
              "United Kingdom"
            ],
            "range": [
              "#7dd3f7",
              "#c4b5fd",
              "#6ee7df",
              "#fcd38a",
              "#fb9fae",
              "#b0bec8",
              "#2563eb"
            ]
          },
          "legend": null
        },
        "strokeWidth": {
          "field": "Country",
          "type": "nominal",
          "scale": {
            "domain": [
              "Canada",
              "France",
              "Germany",
              "Italy",
              "Japan",
              "United States",
              "United Kingdom"
            ],
            "range": [2, 2, 2, 2, 2, 2, 5]
          },
          "legend": null
        },
        "tooltip": [
          {"field": "Quarter", "type": "ordinal", "title": "Quarter"},
          {"field": "Country", "type": "nominal", "title": "Country"},
          {
            "field": "GFCF",
            "type": "quantitative",
            "title": "% of GDP",
            "format": ".1f"
          }
        ]
      }
    },
    {
      "mark": {
        "type": "text",
        "align": "left",
        "dx": 6,
        "fontSize": 12,
        "fontWeight": "bold",
        "font": "Instrument Sans, sans-serif"
      },
      "encoding": {
        "x": {"aggregate": "max", "field": "Quarter", "type": "ordinal"},
        "y": {
          "aggregate": {"argmax": "Quarter"},
          "field": "GFCF",
          "type": "quantitative"
        },
        "text": {"field": "Country", "type": "nominal"},
        "color": {
          "field": "Country",
          "type": "nominal",
          "scale": {
            "domain": [
              "Canada",
              "France",
              "Germany",
              "Italy",
              "Japan",
              "United States",
              "United Kingdom"
            ],
            "range": [
              "#7dd3f7",
              "#c4b5fd",
              "#6ee7df",
              "#fcd38a",
              "#fb9fae",
              "#b0bec8",
              "#2563eb"
            ]
          },
          "legend": null
        }
      }
    }
  ],
  "config": {
    "font": "Instrument Sans, sans-serif",
    "view": {"stroke": "transparent"},
    "background": "#F8FAFC",
    "axis": {
      "labelColor": "#676A86",
      "labelFontSize": 11,
      "labelFont": "Instrument Sans, sans-serif",
      "labelOpacity": 0.7,
      "tickColor": "#676A86",
      "tickOpacity": 0.5,
      "domainColor": "#676A86",
      "domainOpacity": 0.5,
      "gridColor": "#676A86",
      "gridDash": [2, 2],
      "gridOpacity": 0.5,
      "titleColor": "#676A86",
      "titleOpacity": 0.8,
      "tickSize": 4
    },
    "axisX": {"grid": false},
    "axisY": {
      "gridColor": "#676A86",
      "gridDash": [1, 5],
      "gridOpacity": 0.5,
      "ticks": false
    },
    "title": {
      "font": "Instrument Sans, sans-serif",
      "fontSize": 16,
      "color": "#1a1a1a",
      "subtitleFontSize": 13,
      "subtitleColor": "#676A86"
    }
  }
}
